# ============================================
# .gitignore — Mentoria Tecnologia Takwara
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# --- macOS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- MkDocs build ---
site/

# --- Transcrições de conversas (NUNCA versionar) ---
# Conversas de WhatsApp, Telegram, chats em geral
**/WhatsApp Chat - */
**/_chat*.txt
**/Conversa do WhatsApp*.txt

# Áudios e vídeos brutos (decupados → .md versionado)
*.wav
*.opus
*.mp3
*.mp4
*.webm
*.ogg

# PDFs originais (extraídos → .md versionado)
*.pdf

# --- EXCEÇÃO: manter pautas e ATAs de reunião ---
# Pautas e ATAs são .md organizados em docs/ - NÃO ignorar
# docs/**/*.md  ← NÃO incluir esta linha

# --- Arquivos temporários de extração ---
_*.txt
_*.py
_*.json

# --- Arquivos grandes / mídia ---
*.jpg
*.jpeg
*.png
*.gif
*.webp
